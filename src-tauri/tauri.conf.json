{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MailDraft",
  "version": "1.5.0",
  "identifier": "com.mori5600.maildraft",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "MailDraft",
        "width": 800,
        "height": 600,
        "maximized": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc: http://ipc.localhost; img-src 'self' data: blob: asset: http://asset.localhost; style-src 'self' 'unsafe-inline'",
      "devCsp": "default-src 'self' ipc: http: ws: data: blob: asset:; connect-src 'self' ipc: http: ws:; img-src 'self' data: blob: asset: http:; style-src 'self' 'unsafe-inline' http:; script-src 'self' 'unsafe-inline' 'unsafe-eval' http:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../THIRD-PARTY-NOTICES.txt": "THIRD-PARTY-NOTICES.txt"
    },
    "license": "MIT",
    "licenseFile": "../LICENSE",
    "windows": {
      "wix": {
        "language": {
          "ja-JP": {
            "localePath": "./wix/locales/ja-JP.wxl"
          }
        }
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
